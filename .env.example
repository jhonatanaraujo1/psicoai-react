# PsicoAI Frontend — Environment Variables
# Copie este arquivo para .env.local e preencha os valores

# URL base do backend (sem barra final)
# Deixe vazio para usar dados mockados (modo demo Vercel)
VITE_API_BASE_URL=

# Exemplo para dev local com backend rodando:
# VITE_API_BASE_URL=http://localhost:8080

# Exemplo para produção:
# VITE_API_BASE_URL=https://api.psicoai.com.br
